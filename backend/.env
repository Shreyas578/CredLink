# Backend Oracle Environment — CredLink

# ── IPFS (Pinata) ──────────────────────────────────────────────────────────
# ⚠️  Fill these with your Pinata API keys (Require 'Admin' or 'Specific Scopes' like pinFileToIPFS)
PINATA_API_KEY=7bdb6deccad87c77a32f
PINATA_SECRET_API_KEY=bb54a9235e87ce5f7082c85baca9d84ed7dafe9d2da8245480036eb8fe55ad8e

# ── Oracle Wallet ─────────────────────────────────────────────────────────
# ⚠️  Fill this with the private key of the wallet that deployed the contracts
# (same as DEPLOYER_PRIVATE_KEY in contracts/.env)
ORACLE_PRIVATE_KEY=c802c867df965db5c0f1d01b813ab1ae01f15024e6b7cff2fb8865eb2859fcee

# ── Creditcoin Testnet RPC ────────────────────────────────────────────────
CREDITCOIN_RPC_URL=https://rpc.cc3-testnet.creditcoin.network

# ── Ollama (WSL) ──────────────────────────────────────────────────────────
# Ollama endpoint accessible from Windows — default WSL port
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=gemma:2b

# ── Server ────────────────────────────────────────────────────────────────
PORT=4000
FRONTEND_URL=http://localhost:3000
